{% extends 'base.html.twig' %}

{% block title %}Sign Up - Discover Tunisia{% endblock %}

{% block body %}
<style>
    .auth-container {
        max-width: 420px;
        margin: 60px auto;
        background: white;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }
    .auth-container h1 {
        text-align: center;
        color: #1a3c5e;
        margin-bottom: 30px;
        font-size: 1.8em;
    }
    .auth-container label {
        display: block;
        margin-bottom: 6px;
        color: #555;
        font-weight: 600;
        font-size: 0.9em;
    }
    .auth-container input[type="email"],
    .auth-container input[type="password"] {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 1em;
        margin-bottom: 20px;
        outline: none;
        transition: border-color 0.2s;
    }
    .auth-container input:focus { border-color: #1a3c5e; }
    .auth-container .checkbox-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
        font-size: 0.9em;
        color: #555;
    }
    .auth-container button {
        width: 100%;
        padding: 13px;
        background: #e67e22;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 1.1em;
        cursor: pointer;
        transition: background 0.2s;
    }
    .auth-container button:hover { background: #cf6d17; }
    .auth-container .bottom-link {
        text-align: center;
        margin-top: 20px;
        color: #777;
        font-size: 0.9em;
    }
    .auth-container .bottom-link a { color: #e67e22; text-decoration: none; }
    .alert-danger {
        background: #fee;
        color: #c0392b;
        padding: 10px 15px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 0.9em;
    }
</style>

<div class="auth-container">
    <h1>🇹🇳 Create Account</h1>

    {% for flash_error in app.flashes('verify_email_error') %}
        <div class="alert-danger">{{ flash_error }}</div>
    {% endfor %}

    {{ form_errors(registrationForm) }}

    {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}
        {{ form_row(registrationForm.email) }}
        {{ form_row(registrationForm.plainPassword, { label: 'Password' }) }}

        <div class="checkbox-row">
            {{ form_widget(registrationForm.agreeTerms) }}
            {{ form_label(registrationForm.agreeTerms) }}
        </div>

        <button type="submit">Create Account</button>
    {{ form_end(registrationForm) }}

    <div class="bottom-link">
        Already have an account? <a href="/login">Login</a>
    </div>
</div>
{% endblock %}
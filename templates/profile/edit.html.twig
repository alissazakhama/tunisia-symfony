{# templates/profile/edit.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Edit Profile{% endblock %}

{% block body %}
<style>
    .profile-edit-container {
        max-width: 560px;
        margin: 2.5rem auto;
        padding: 0 1.25rem 3rem;
        font-family: sans-serif;
    }

    .edit-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 1.75rem;
    }

    .edit-header h1 {
        margin: 0;
        font-size: 1.7em;
        color: #1a3c5e;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 16px;
        background: #f0f5f9;
        color: #1a3c5e;
        border-radius: 20px;
        font-size: 0.88em;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.2s, color 0.2s;
        white-space: nowrap;
    }

    .back-btn:hover {
        background: #1a3c5e;
        color: white;
    }

    .form-section {
        background: white;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        padding: 28px 32px;
        margin-bottom: 24px;
    }

    .form-section h2 {
        margin: 0 0 20px;
        font-size: 1.1em;
        color: #1a3c5e;
        font-weight: 700;
        border-bottom: 2px solid #f0f5f9;
        padding-bottom: 10px;
    }

    .alert {
        padding: 0.75rem 1rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: 0.92em;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .alert-error {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }

    input[type="text"],
    input[type="password"] {
        width: 100%;
        padding: 0.55rem 0.85rem;
        margin-top: 0.25rem;
        border: 1px solid #d0d7de;
        border-radius: 8px;
        box-sizing: border-box;
        font-size: 0.95em;
        transition: border-color 0.2s;
    }

    input[type="text"]:focus,
    input[type="password"]:focus {
        outline: none;
        border-color: #1a6b8a;
        box-shadow: 0 0 0 3px rgba(26,107,138,0.1);
    }

    button[type="submit"] {
        margin-top: 1rem;
        padding: 0.55rem 1.5rem;
        background: #1a3c5e;
        color: #fff;
        border: none;
        border-radius: 20px;
        font-size: 0.9em;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

    button[type="submit"]:hover {
        background: #e67e22;
    }
</style>

<div class="profile-edit-container">

    <div class="edit-header">
        <a href="{{ path('app_profile') }}" class="back-btn">← Back to Profile</a>
        <h1>Edit Profile</h1>
    </div>

    {# Flash messages #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">✅ {{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-error">⚠️ {{ message }}</div>
    {% endfor %}

    {# ── Update Username ── #}
    <section class="form-section">
        <h2>👤 Change Username</h2>
        {{ form_start(usernameForm) }}
            {{ form_row(usernameForm.username) }}
            {{ form_row(usernameForm.save) }}
        {{ form_end(usernameForm) }}
    </section>

    {# ── Update Password ── #}
    <section class="form-section">
        <h2>🔒 Change Password</h2>
        {{ form_start(passwordForm) }}
            {{ form_row(passwordForm.currentPassword) }}
            {{ form_row(passwordForm.newPassword.first) }}
            {{ form_row(passwordForm.newPassword.second) }}
            {{ form_row(passwordForm.save) }}
        {{ form_end(passwordForm) }}
    </section>

</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Destinations - Tunisia{% endblock %}

{% block body %}

<style>
    .page-header {
        background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), #1a6b8a;
        padding: 60px 20px;
        text-align: center;
        color: white;
    }

    .page-header h1 {
        font-size: 2.5em;
    }

    .search-container {
        display: flex;
        justify-content: center;
        padding: 30px 20px;
    }

    .search-container input {
        width: 100%;
        max-width: 500px;
        padding: 14px 22px;
        font-size: 16px;
        border: 2px solid #d0daea;
        border-radius: 30px;
        outline: none;
    }

    .destinations {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 25px;
        padding: 20px 40px 60px;
    }

    .destination-wrapper {
        position: relative;
    }

    .card {
        width: 220px;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        text-decoration: none;
        color: #333;
        transition: transform 0.2s;
        background: white;
        display: block;
    }

    .card:hover {
        transform: translateY(-5px);
    }

    .card img {
        width: 100%;
        height: 150px;
        object-fit: cover;
        display: block;
        background: #d0daea;
    }

    .card h3 {
        padding: 10px;
        text-align: center;
        margin: 0;
    }

    .wishlist-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        z-index: 100;
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: white;
        text-decoration: none;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 22px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.25);
        transition: transform 0.2s;
    }

    .wishlist-btn:hover {
        transform: scale(1.1);
    }
</style>

<div class="page-header">
    <h1>Destinations</h1>
</div>

<div class="search-container">
    <input
        type="text"
        id="search"
        placeholder="🔍 Search destinations..."
        onkeyup="searchDestinations()"
    >
</div>

<div class="destinations" id="destinationsGrid">

    {% for destination in destinations %}
        <div class="destination-wrapper">

            {% if app.user %}
                <a
                    href="{{ path('app_wishlist_toggle', { id: destination.id }) }}"
                    class="wishlist-btn"
                >
                    ❤️
                </a>
            {% endif %}

            <a
                class="card"
                href="{{ path('app_destination_show', { id: destination.id }) }}"
            >
                <img
                    src="{{ asset(destination.image_path) }}"
                    alt="{{ destination.name }}"
                    loading="lazy"
                    onerror="this.onerror=null;this.src='{{ asset(placeholder_image) }}';"
                >

                <h3>{{ destination.name }}</h3>
            </a>

        </div>
    {% endfor %}

</div>

<script>
function searchDestinations() {
    const input = document.getElementById('search').value.toLowerCase();
    const cards = document.querySelectorAll('#destinationsGrid .destination-wrapper');

    cards.forEach(function(card) {
        const name = card.querySelector('h3').textContent.toLowerCase();

        card.style.display = name.includes(input)
            ? ''
            : 'none';
    });
}
</script>

{% endblock %}

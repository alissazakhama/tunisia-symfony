{% extends 'base.html.twig' %}

{% block title %}Destinations - Tunisia{% endblock %}

{% block body %}
<style>
    .page-header {
        background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), #1a6b8a;
        padding: 60px 20px;
        text-align: center;
        color: white;
    }
    .page-header h1 { font-size: 2.5em; }
    .search-container {
        display: flex;
        justify-content: center;
        padding: 30px 20px;
    }
    .search-container input {
        width: 100%;
        max-width: 500px;
        padding: 14px 22px;
        font-size: 16px;
        border: 2px solid #d0daea;
        border-radius: 30px;
        outline: none;
    }
    .destinations {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 25px;
        padding: 20px 40px 60px;
    }
    .card {
        width: 220px;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        text-decoration: none;
        color: #333;
        transition: transform 0.2s;
    }
    .card:hover { transform: translateY(-5px); }
    .card img { width: 100%; height: 150px; object-fit: cover; }
    .card h3 { padding: 10px; text-align: center; }
</style>

<div class="page-header">
    <h1>Destinations</h1>
</div>

<div class="search-container">
    <input type="text" id="search" placeholder="🔍 Search destinations..." onkeyup="searchDestinations()">
</div>

<div class="destinations" id="destinationsGrid">
    {% for destination in destinations %}
    <a class="card" href="/destinations/{{ destination.id }}">
        <h3>{{ destination.name }}</h3>
    </a>
    {% endfor %}
</div>

<script>
function searchDestinations() {
    const input = document.getElementById('search').value.toLowerCase();
    const cards = document.querySelectorAll('#destinationsGrid a');
    cards.forEach(function(card) {
        const name = card.querySelector('h3').textContent.toLowerCase();
        card.style.display = name.includes(input) ? '' : 'none';
    });
}
</script>
{% endblock %}
  function normalise(name) {
    return name.toLowerCase().trim().replace(/\s+/g,' ');
  }
  function getCoords(dest) {
    let coords;

    if (dest.cx !== null && dest.cy !== null) {
      // dest.cx/cy supplied in old (0 0 300 520) space — remap to new SVG space
      coords = {
        cx: 250 + (dest.cx / 300) * 460,
        cy: -2  + (dest.cy / 520) * 964
      };
    } else {
      const key = normalise(dest.name);
      coords = COORD_FALLBACK[key] || null;
    }

    if (!coords) return null;
    return coords;
  }

  /* ── DOM refs ── */
  const pinsLayer  = document.getElementById('pins-layer');
  const tooltip    = document.getElementById('mapTooltip');
  const hoverCard  = document.getElementById('hoverCard');
  const hoverImg   = document.getElementById('hoverImg');
  const hoverName  = document.getElementById('hoverName');
  const hoverDesc  = document.getElementById('hoverDesc');
  const hoverRegion= document.getElementById('hoverRegion');
  const mapPanel   = document.getElementById('mapPanel');

  /* ── Build pins ── */
  DESTINATIONS.forEach(dest => {
    const coords = getCoords(dest);
    if (!coords) return;                 // skip if no coords available

    const g = document.createElementNS('http://www.w3.org/2000/svg','g');
    g.classList.add('dest-pin');
    g.setAttribute('data-id', dest.id);
    g.setAttribute('tabindex', '0');
    g.setAttribute('role', 'button');
    g.setAttribute('aria-label', dest.name);

    const r1 = 11, r2 = 7;
    const cx = coords.cx, cy = coords.cy;

    g.innerHTML = `
      <circle class="pin-outer"  cx="${cx}" cy="${cy}" r="${r1}" />
      <circle class="pin-circle" cx="${cx}" cy="${cy}" r="${r2}" filter="url(#pinGlow)" />
      <text class="pin-label" x="${cx}" y="${cy - r1 - 3}" text-anchor="middle">${dest.name}</text>
    `;

    g.addEventListener('mouseenter', e => showHover(dest, e));
    g.addEventListener('mousemove',  e => moveHover(e));
    g.addEventListener('mouseleave',    hideHover);
    g.addEventListener('click', () => { window.location.href = dest.url; });

    pinsLayer.appendChild(g);
  });

  /* ── Hover card logic ── */
  let hoverTimeout;

  function showHover(dest, e) {
    clearTimeout(hoverTimeout);
    hoverImg.src    = dest.image;
    hoverImg.onerror = () => { hoverImg.src = dest.placeholder; };
    hoverName.textContent   = dest.name;
    hoverDesc.textContent   = dest.description || '';
    hoverRegion.textContent = dest.region || 'Tunisia';

    moveHover(e);
    hoverCard.classList.add('visible');

    // Highlight list item
    document.querySelectorAll('.dest-item').forEach(el => el.classList.remove('active'));
    const li = document.getElementById('list-item-' + dest.id);
    if (li) {
      li.classList.add('active');
      li.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    // Show tooltip
    tooltip.textContent = dest.name;
    tooltip.classList.add('visible');
  }

  function moveHover(e) {
    const pad = 16;
    let x = e.clientX + pad;
    let y = e.clientY - 10;
    const w = hoverCard.offsetWidth  || 230;
    const h = hoverCard.offsetHeight || 220;
    if (x + w > window.innerWidth  - pad) x = e.clientX - w - pad;
    if (y + h > window.innerHeight - pad) y = e.clientY - h - pad;
    hoverCard.style.left = x + 'px';
    hoverCard.style.top  = y + 'px';

    // Position tooltip on map panel
    const rect = mapPanel.getBoundingClientRect();
    tooltip.style.left = (e.clientX - rect.left - tooltip.offsetWidth / 2) + 'px';
    tooltip.style.top  = (e.clientY - rect.top  - 48) + 'px';
  }

  function hideHover() {
    hoverTimeout = setTimeout(() => {
      hoverCard.classList.remove('visible');
      tooltip.classList.remove('visible');
      document.querySelectorAll('.dest-item').forEach(el => el.classList.remove('active'));
    }, 120);
  }

  /* ── List item hover syncs with pins ── */
  document.querySelectorAll('.dest-item').forEach(item => {
    item.addEventListener('mouseenter', function (e) {
      const id   = this.dataset.id;
      const dest = DESTINATIONS.find(d => d.id === id);
      if (!dest) return;
      // Fake a position near the pin
      const pin = pinsLayer.querySelector(`[data-id="${id}"]`);
      if (pin) {
        const r = pin.getBoundingClientRect();
        const fakeEvent = { clientX: r.left + r.width/2, clientY: r.top + r.height/2,
                            target: pin };
        showHover(dest, fakeEvent);
      }
    });
    item.addEventListener('mouseleave', hideHover);
  });

})();
</script>
{% endblock %}

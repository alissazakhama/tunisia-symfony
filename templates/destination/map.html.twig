  </div>

  {# ── Right: Destination list ── #}
  <aside class="info-panel">
    <div class="info-panel-header">
      <h2>Destinations</h2>
      <p>{{ destinations | length }} place{{ destinations | length != 1 ? 's' : '' }} to discover</p>
    </div>
    <div class="dest-list" id="destList">
      {% for dest in destinations %}
      <a class="dest-item" id="list-item-{{ dest.id }}"
         href="{{ path('app_destination_show', { id: dest.id }) }}"
         data-id="{{ dest.id }}">
        <img class="dest-thumb"
             src="{{ asset(dest.image_path) }}"
             alt="{{ dest.name }}"
             loading="lazy"
             onerror="this.src='{{ asset(placeholder_image) }}'">
        <div class="dest-info">
          <h3>{{ dest.name }}</h3>
          <p>{{ dest.region is defined ? dest.region : 'Tunisia' }}</p>
        </div>
      </a>
      {% endfor %}
    </div>
  </aside>
</div>

{# ── Hover card (follows cursor) ── #}
<div class="hover-card" id="hoverCard">
  <img id="hoverImg" src="" alt="">
  <div class="hover-card-body">
    <h4 id="hoverName"></h4>
    <p  id="hoverDesc"></p>
    <span class="hover-card-tag" id="hoverRegion"></span>
  </div>
</div>

<script>
(function () {
  /* ─────────────────────────────────────────────
     Default coordinate fallback table.
     If a destination in the catalog does NOT have
     map_cx / map_cy properties, we look it up here
     by a normalised version of its name.
     All coords are on the SVG viewBox (0 0 300 520).
  ───────────────────────────────────────────── */
  /*
     Coordinate mapping formula used for all entries:
       x = 22 + (lon - 7.50) * 62
       y = 22 + (37.55 - lat) * 62
     All coordinates are on the SVG viewBox (0 0 300 520).
  */

{% extends 'base.html.twig' %}

{% block title %}Explore Tunisia – Interactive Map{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Lato:wght@300;400;600&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
<style>
  /* ── Root tokens ── */
  :root {
    --sand:      #e8d5b0;
    --sand-light:#f5ead3;
    --terracotta:#c0533a;
    --gold:      #c9963a;
    --sea:       #2d7d9a;
    --sea-light: #4da8c4;
    --ink:       #1b2430;
    --cream:     #faf6ee;
    --shadow:    rgba(27,36,48,0.18);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Lato', sans-serif;
    background: var(--cream);
    color: var(--ink);
    min-height: 100vh;
  }

  /* ── Page header ── */
  .map-header {
    background: var(--ink);
    padding: 42px 40px 36px;
    display: flex;
    align-items: flex-end;
    gap: 18px;
    border-bottom: 3px solid var(--gold);
  }
  .map-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2.6rem;
    color: var(--sand-light);
    line-height: 1;
  }
  .map-header p {
    color: var(--sand);
    font-size: 0.95rem;
    font-weight: 300;
    margin-left: auto;
    text-align: right;
    max-width: 280px;
    line-height: 1.5;
  }

  /* ── Layout ── */
  .map-layout {
    display: flex;
    min-height: calc(100vh - 110px);
  }

  /* ── Map panel ── */
  .map-panel {
    flex: 1 1 55%;
    position: relative;
    background: linear-gradient(160deg, #d6eaf5 0%, #c2dde8 60%, #b0cdd6 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .map-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 30% 20%, rgba(255,255,255,0.15) 0%, transparent 50%),
      radial-gradient(circle at 70% 80%, rgba(45,125,154,0.12) 0%, transparent 50%);
    pointer-events: none;
  }

  /* Tunisia SVG map */
  #tunisia-map {
    width: 100%;
    max-width: 420px;
    height: auto;
    filter: drop-shadow(0 8px 24px rgba(27,36,48,0.22));
    position: relative;
    z-index: 1;
  }

  /* Country shape */
  .tn-country {
    fill: var(--sand);
    stroke: #9aab89;
    stroke-width: 1.5;
    transition: fill 0.3s;
  }

  /* Destination pins */
  .dest-pin {
    cursor: pointer;
    transition: transform 0.2s;
    transform-origin: center;
    transform-box: fill-box;
  }
  .dest-pin:hover { transform: scale(1.35); }
  .dest-pin:hover .pin-circle { fill: var(--terracotta); }

  .pin-outer {
    fill: none;
    stroke: white;
    stroke-width: 2;
    opacity: 0.7;
  }
  .pin-circle {
    fill: var(--gold);
    transition: fill 0.2s;
  }
  .pin-label {
    font-family: 'Lato', sans-serif;
    font-size: 13px;
    font-weight: 600;
    fill: var(--ink);
    pointer-events: none;
    paint-order: stroke;
    stroke: white;
    stroke-width: 4;
    stroke-linejoin: round;
  }

  /* ── Tooltip ── */
  .map-tooltip {
    position: absolute;
    background: var(--ink);
    color: var(--sand-light);
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 0.82rem;
    font-weight: 600;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.18s, transform 0.18s;
    z-index: 999;
    border: 1px solid var(--gold);
    letter-spacing: 0.04em;
  }
  .map-tooltip.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .map-tooltip::after {
    content: '';
    position: absolute;
    bottom: -7px;
    left: 50%;
    transform: translateX(-50%);
    border: 7px solid transparent;
    border-bottom: none;
    border-top-color: var(--gold);
  }

  /* ── Info panel (right) ── */
  .info-panel {
    flex: 0 0 380px;
    background: white;
    border-left: 1px solid #e4ddd0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .info-panel-header {
    padding: 28px 28px 20px;
    border-bottom: 2px solid var(--sand);
  }
  .info-panel-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: var(--ink);
  }
  .info-panel-header p {
    font-size: 0.82rem;
    color: #888;
    margin-top: 4px;
    font-weight: 300;
  }

  /* Destination list */
  .dest-list {
    flex: 1;
    overflow-y: auto;
    padding: 16px 0;
  }
  .dest-list::-webkit-scrollbar { width: 4px; }
  .dest-list::-webkit-scrollbar-thumb { background: var(--sand); border-radius: 2px; }

  .dest-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 24px;
    cursor: pointer;
    transition: background 0.15s;
    border-left: 3px solid transparent;
    text-decoration: none;
    color: inherit;
  }
  .dest-item:hover,
  .dest-item.active {
    background: var(--sand-light);
    border-left-color: var(--terracotta);
  }

  .dest-thumb {
    width: 60px;
    height: 46px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
    background: var(--sand);
    border: 1.5px solid #d8ccba;
  }

  .dest-info h3 {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--ink);
  }
  .dest-info p {
    font-size: 0.78rem;
    color: #888;
    margin-top: 2px;
    font-weight: 300;
  }

  /* ── Hover card (floating image popup) ── */
  .hover-card {
    position: fixed;
    width: 230px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 12px 40px var(--shadow);
    overflow: hidden;
    pointer-events: none;
    opacity: 0;
    transform: scale(0.92) translateY(8px);
    transition: opacity 0.22s, transform 0.22s;
    z-index: 1000;
    border: 2px solid var(--gold);
  }
  .hover-card.visible {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
  .hover-card img {
    width: 100%;
    height: 140px;
    object-fit: cover;
    display: block;
  }
  .hover-card-body {
    padding: 12px 14px 14px;
  }
  .hover-card-body h4 {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    color: var(--ink);
  }
  .hover-card-body p {
    font-size: 0.75rem;
    color: #888;
    margin-top: 4px;
    font-weight: 300;
    line-height: 1.5;
  }
  .hover-card-tag {
    display: inline-block;
    margin-top: 8px;
    background: var(--sand-light);
    color: var(--terracotta);
    font-size: 0.68rem;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .map-layout { flex-direction: column; }
    .info-panel { flex: none; border-left: none; border-top: 1px solid #e4ddd0; }
    .map-header { flex-direction: column; align-items: flex-start; gap: 8px; }
    .map-header p { margin-left: 0; text-align: left; }
  }
</style>

{# ── Build a JS-friendly destinations array from Twig ── #}
<script>
  const DESTINATIONS = [
    {% for dest in destinations %}
    {
      id:          "{{ dest.id }}",
      name:        "{{ dest.name | e('js') }}",
      description: "{{ dest.description is defined ? dest.description | slice(0,80) | e('js') : '' }}",
      image:       "{{ asset(dest.image_path) }}",
      placeholder: "{{ asset(placeholder_image) }}",
      url:         "{{ path('app_destination_show', { id: dest.id }) }}",
      /* Coordinates mapped per known Tunisian destinations (cx/cy on the SVG viewBox 0 0 300 520) */
      cx: {{ dest.map_cx is defined ? dest.map_cx : 'null' }},
      cy: {{ dest.map_cy is defined ? dest.map_cy : 'null' }},
      region: "{{ dest.region is defined ? dest.region | e('js') : 'Tunisia' }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ];
</script>

{# ── Page ── #}

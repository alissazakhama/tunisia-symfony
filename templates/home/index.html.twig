{% extends 'base.html.twig' %}

{% block title %}Discover Tunisia{% endblock %}
{% block stylesheets %}
<style>
  #plannerOverlay.open { display:block !important; }

  .planner-step { display:none; }
  .planner-step.active { display:block; }

  .planner-dot {
    width:32px; height:32px; border-radius:50%;
    background:#e0e0e0; color:#999; font-weight:700; font-size:0.9em;
    display:flex; align-items:center; justify-content:center;
    transition:background 0.3s, color 0.3s; flex-shrink:0;
  }
  .planner-dot.active { background:#e67e22; color:white; }
  .planner-dot.done   { background:#1a3c5e; color:white; }
  .planner-line { flex:1; height:3px; background:#e0e0e0; transition:background 0.3s; }
  .planner-line.done  { background:#1a3c5e; }


  .dest-chip {
    border:2px solid #e0e8f0; border-radius:12px; padding:14px 10px;
    text-align:center; cursor:pointer; transition:all 0.2s; position:relative;
    background:white;
  }
  .dest-chip:hover { border-color:#e67e22; transform:translateY(-2px); box-shadow:0 4px 14px rgba(0,0,0,0.1); }
  .dest-chip.chosen { border-color:#1a3c5e; background:#f0f5f9; }
  .chip-emoji  { font-size:1.8em; margin-bottom:6px; }
  .chip-name   { font-weight:700; color:#1a3c5e; font-size:0.9em; }
  .chip-region { font-size:0.75em; color:#aaa; margin-top:2px; }
  .chip-check  { display:none; position:absolute; top:6px; right:8px; color:#e67e22; font-weight:900; font-size:0.85em; }
  .dest-chip.chosen .chip-check { display:flex; }

  .plan-summary { display:flex; gap:20px; margin-bottom:20px; flex-wrap:wrap; }
  .sum-item { background:#f0f5f9; border-radius:12px; padding:16px 24px; text-align:center; flex:1; min-width:80px; }
  .sum-num  { font-size:2em; font-weight:800; color:#1a3c5e; }
  .sum-lbl  { font-size:0.8em; color:#888; margin-top:2px; }

  .plan-route { display:flex; align-items:center; flex-wrap:wrap; gap:8px; margin-bottom:16px; }
  .route-label { font-weight:700; color:#1a3c5e; font-size:0.9em; }
  .route-chip  { background:#1a3c5e; color:white; padding:5px 14px; border-radius:20px; font-size:0.85em; font-weight:600; text-decoration:none; transition:background 0.2s; }
  .route-chip:hover { background:#e67e22; }
  .route-arrow { color:#aaa; font-size:1.1em; }

  .plan-tip { background:#fff8e6; border-left:4px solid #e67e22; padding:12px 16px; border-radius:8px; margin-bottom:20px; font-size:0.9em; color:#444; display:flex; gap:10px; align-items:flex-start; }

  .plan-day-card { border:1px solid #e8edf3; border-radius:14px; margin-bottom:20px; overflow:hidden; }
  .plan-day-header { background:#1a3c5e; color:white; padding:14px 20px; display:flex; align-items:center; gap:14px; }
  .plan-day-num { width:36px; height:36px; border-radius:50%; background:#e67e22; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:1em; flex-shrink:0; }
  .plan-day-title { font-weight:700; font-size:1em; }
  .plan-day-theme { font-size:0.8em; opacity:0.75; margin-top:2px; }
  .travel-note-bar { background:#fff3cd; padding:10px 20px; font-size:0.88em; color:#856404; border-bottom:1px solid #ffeaa7; }
  .plan-day-body { padding:16px 20px; display:flex; flex-direction:column; gap:12px; }

  .place-item { display:flex; gap:14px; align-items:flex-start; }
  .place-time { font-size:0.8em; font-weight:700; color:#e67e22; white-space:nowrap; padding-top:3px; min-width:65px; }
  .place-info h4 { margin:0 0 4px; font-size:0.95em; color:#1a3c5e; }
  .place-info p  { margin:0 0 6px; font-size:0.85em; color:#666; line-height:1.5; }
  .place-tag { display:inline-block; padding:2px 10px; border-radius:12px; font-size:0.75em; font-weight:600; }

  .day-tip { background:#f0f5f9; border-radius:8px; padding:10px 14px; font-size:0.85em; color:#555; margin-top:4px; }

  #toStep2[disabled] { opacity:0.4; cursor:not-allowed; }

  #openPlannerBtn:hover { background:#cf6d17 !important; transform:translateY(-2px); }
</style>
{% endblock %}
{% block body %}
<style>
    .hero {
        position: relative;
        height: 500px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: white;
        background: #1a6b8a;
    }
    .hero img.hero-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
    }
    .hero .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.55));
        z-index: 1;
    }
    .hero .hero-inner {
        position: relative;
        z-index: 2;
        padding: 0 20px;
    }
    .hero h1 { font-size: 3em; margin-bottom: 10px; }
    .hero p { font-size: 1.3em; }
    .hero a {
        display: inline-block;
        margin-top: 20px;
        padding: 12px 30px;
        background: #e67e22;
        color: white;
        text-decoration: none;
        border-radius: 5px;
        font-size: 1.1em;
    }
    .hero a:hover { background: #cf6d17; }
    .experiences-section {
        background: #b8d9e8;
        padding: 56px 24px 64px;
    }
    .experiences-section h2 {
        text-align: center;
        color: #1a3c5e;
        font-size: 1.6em;
        margin: 0 0 36px;
    }
    .sections {
        display: flex;
        justify-content: center;
        gap: 24px;
        flex-wrap: wrap;
        max-width: 1100px;
        margin: 0 auto;
    }
    .section-card {
        width: 240px;
        text-align: center;
        padding: 28px 22px 32px;
        border: 2px solid rgba(255, 255, 255, 0.75);
        border-radius: 16px;
        text-decoration: none;
        color: #1a3c5e;
        background: rgba(255, 255, 255, 0.35);
        backdrop-filter: blur(4px);
        transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
        box-shadow: 0 4px 14px rgba(26, 60, 94, 0.08);
    }
    .section-card:hover {
        transform: translateY(-6px);
        background: rgba(255, 255, 255, 0.55);
        box-shadow: 0 8px 24px rgba(26, 60, 94, 0.12);
    }
    .section-card .card-emoji {
        font-size: 2.8rem;
        display: block;
        margin-bottom: 12px;
        line-height: 1;
    }
    .section-card .card-image-zone {
        width: 100%;
        height: 100px;
        margin-bottom: 14px;
        border-radius: 10px;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.5);
    }
    .section-card .card-image-zone img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
    .section-card h3 {
        margin: 0 0 10px;
        font-size: 1.15em;
        color: #1a3c5e;
    }
    .section-card p {
        margin: 0;
        font-size: 0.95em;
        color: #2d4a63;
        line-height: 1.5;
    }
</style>
{% if is_granted('ROLE_USER') %}
<div style="text-align:center; margin: 40px 0;">
    <a href="#" id="openPlannerBtn" style="
        display: inline-block;
        background: #e67e22;
        color: white;
        padding: 16px 36px;
        border-radius: 30px;
        font-size: 1.15em;
        font-weight: 700;
        text-decoration: none;
        box-shadow: 0 4px 18px rgba(230,126,34,0.35);
        letter-spacing: 0.5px;
        transition: background 0.2s, transform 0.15s;
    ">🗺️ Plan Your Tunisia Trip</a>
</div>
{% endif %}
<div class="hero">
    <img
        class="hero-bg"
        src="{{ asset(hero_image) }}"
        alt="Tunisia landscape"
        onerror="this.onerror=null;this.src='{{ asset(placeholder_image)|e('html_attr') }}';"
    >
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-inner">
        <h1>Welcome to Tunisia</h1>
        <p>Experience the beauty of the Mediterranean and the magic of the Sahara.</p>
        <a href="{{ path('app_destinations') }}">Explore Destinations</a>
    </div>
</div>

<section class="experiences-section">
    <h2>Explore by experience</h2>
    <div class="sections">
        {% for card in experience_cards %}
            <a class="section-card" href="{{ path('app_experience_show', { id: card.id }) }}">
                <span class="card-emoji" aria-hidden="true">{{ card.emoji }}</span>
                <div class="card-image-zone">
                    <img
                        src="{{ asset(card.image_path) }}"
                        alt="{{ card.name }}"
                        loading="lazy"
                        onerror="this.onerror=null;this.src='{{ asset(placeholder_image)|e('html_attr') }}';"
                    >
                </div>
                <h3>{{ card.name }}</h3>
                <p>{{ card.summary }}</p>
            </a>
        {% endfor %}
    </div>
</section>
<div id="plannerOverlay" style="display:none; position:fixed; inset:0; background:rgba(10,20,40,0.7); z-index:1000; overflow-y:auto; backdrop-filter:blur(4px);">
  <div style="max-width:820px; margin:40px auto; background:white; border-radius:20px; padding:36px 40px; position:relative; box-shadow:0 20px 60px rgba(0,0,0,0.3);">

    <!-- Close button -->
    <button id="plannerClose" style="position:absolute;top:16px;right:20px;background:none;border:none;font-size:1.5em;cursor:pointer;color:#888;">✕</button>

    <h2 style="color:#1a3c5e;margin:0 0 6px;font-size:1.7em;">🗺️ Plan Your Tunisia Trip</h2>
    <p style="color:#888;margin:0 0 28px;font-size:0.95em;">Pick destinations, set your days, and get a personalised day-by-day itinerary.</p>

    <!-- Progress dots -->
    <div style="display:flex;align-items:center;gap:0;margin-bottom:32px;">
      <div id="dot1" class="planner-dot active">1</div>
      <div id="line1" class="planner-line"></div>
      <div id="dot2" class="planner-dot">2</div>
      <div id="line2" class="planner-line"></div>
      <div id="dot3" class="planner-dot">3</div>
    </div>

    <!-- Choose destinations -->
    <div id="step1" class="planner-step active">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
        <h3 style="margin:0;color:#1a3c5e;">Step 1 — Choose your destinations</h3>
        <button id="selectAllBtn" style="background:#f0f5f9;border:none;padding:7px 16px;border-radius:20px;font-size:0.88em;font-weight:600;color:#1a3c5e;cursor:pointer;">Select All</button>
      </div>
      <div id="destGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;margin-bottom:24px;"></div>
      <div style="text-align:right;">
        <button id="toStep2" disabled style="background:#e67e22;color:white;border:none;padding:11px 28px;border-radius:20px;font-weight:700;font-size:0.97em;cursor:pointer;opacity:0.5;">Next →</button>
      </div>
    </div>

    <!-- Choose days -->
    <div id="step2" class="planner-step">
      <h3 style="color:#1a3c5e;margin:0 0 20px;">Step 2 — How many days?</h3>
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:14px;">
        <button id="daysDown" style="width:40px;height:40px;border-radius:50%;border:2px solid #1a3c5e;background:white;color:#1a3c5e;font-size:1.3em;cursor:pointer;font-weight:700;">−</button>
        <input id="daysVal" type="number" value="5" min="1" readonly style="width:60px;text-align:center;border:2px solid #e0e0e0;border-radius:10px;padding:8px;font-size:1.2em;font-weight:700;color:#1a3c5e;">
        <button id="daysUp" style="width:40px;height:40px;border-radius:50%;border:2px solid #1a3c5e;background:white;color:#1a3c5e;font-size:1.3em;cursor:pointer;font-weight:700;">+</button>
      </div>
      <p id="daysHint" style="color:#888;font-size:0.9em;margin-bottom:24px;"></p>
      <div style="display:flex;gap:12px;">
        <button id="toStep1" style="background:#f0f5f9;border:none;padding:11px 24px;border-radius:20px;font-weight:600;color:#1a3c5e;cursor:pointer;">← Back</button>
        <button id="toStep3" style="background:#e67e22;color:white;border:none;padding:11px 28px;border-radius:20px;font-weight:700;font-size:0.97em;cursor:pointer;">Generate My Plan ✨</button>
      </div>
    </div>

    <!-- Plan output -->
    <div id="step3" class="planner-step">
      <div id="generatingBox" style="text-align:center;padding:40px 0;">
        <div style="font-size:2em;margin-bottom:12px;">✈️</div>
        <p style="color:#1a3c5e;font-weight:600;">Building your personalised itinerary…</p>
      </div>
      <div id="errorBanner" style="display:none;background:#fee;color:#c0392b;padding:12px 16px;border-radius:8px;margin-bottom:16px;"></div>
      <div id="planOutput"></div>
      <div id="planActions" style="display:none;margin-top:20px;display:flex;gap:12px;flex-wrap:wrap;">
        <button id="toStep1b" style="background:#f0f5f9;border:none;padding:11px 24px;border-radius:20px;font-weight:600;color:#1a3c5e;cursor:pointer;">← Change Destinations</button>
        <button id="toStep2b" style="background:#f0f5f9;border:none;padding:11px 24px;border-radius:20px;font-weight:600;color:#1a3c5e;cursor:pointer;">← Change Days</button>
        <button id="replanBtn" style="background:#e67e22;color:white;border:none;padding:11px 24px;border-radius:20px;font-weight:700;cursor:pointer;">🔄 Regenerate</button>
      </div>
    </div>

  </div>
</div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/planner.js') }}"></script>
{% endblock %}
